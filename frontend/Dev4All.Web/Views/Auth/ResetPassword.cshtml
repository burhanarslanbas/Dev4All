@model Dev4All.Web.Models.Auth.ResetPasswordViewModel

@{
    ViewData["Title"] = "Şifre Sıfırla";
}

<div class="min-h-screen flex items-center justify-center p-6 bg-background">
    <main class="w-full max-w-xl bg-surface-container-lowest rounded-3xl p-10 shadow-[0_8px_40px_rgba(19,27,46,0.06)] border border-outline-variant/30">
        <h1 class="text-3xl font-headline font-extrabold text-on-surface mb-3 text-center">Şifre Sıfırla</h1>

        @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
        {
            <div class="mb-6 px-4 py-3 rounded-xl @(Model.Completed ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700")">
                @Model.ResultMessage
            </div>
        }

        @if (!Model.Completed)
        {
            <form asp-action="ResetPassword" asp-controller="Auth" method="post" class="space-y-4">
                @Html.AntiForgeryToken()
                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-error text-sm font-semibold"></div>

                <div>
                    <label asp-for="NewPassword" class="block mb-1 text-sm text-on-surface-variant"></label>
                    <input asp-for="NewPassword" type="password" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary/40" />
                    <span asp-validation-for="NewPassword" class="text-error text-xs"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block mb-1 text-sm text-on-surface-variant"></label>
                    <input asp-for="ConfirmPassword" type="password" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-primary/40" />
                    <span asp-validation-for="ConfirmPassword" class="text-error text-xs"></span>
                </div>

                <button type="submit" class="w-full py-3 rounded-xl bg-primary text-on-primary font-bold hover:opacity-90 transition-opacity">
                    Şifremi Güncelle
                </button>
            </form>
        }

        <div class="mt-8 text-center">
            <a asp-controller="Auth" asp-action="Login" class="text-primary font-semibold hover:underline">Giriş sayfasına dön</a>
        </div>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
