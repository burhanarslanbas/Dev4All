@model Dev4All.Web.Models.Auth.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="min-h-screen flex items-center justify-center p-6 bg-background w-full">
    <div class="w-full max-w-md bg-surface-container-lowest rounded-3xl p-8 shadow-[0_8px_40px_rgba(19,27,46,0.06)] border border-outline-variant/30">

        <div class="mb-8 text-center">
            <a asp-controller="Home" asp-action="Index" class="text-xl font-extrabold text-on-surface font-headline tracking-tight">Dev4All</a>
        </div>

        @if (Model.Submitted)
        {
            <div class="text-center space-y-4">
                <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto">
                    <span class="material-symbols-outlined text-primary text-3xl">mark_email_read</span>
                </div>
                <h2 class="text-xl font-bold font-headline text-on-surface">E-posta Gönderildi</h2>
                <p class="text-sm text-on-surface-variant">
                    Eğer <strong>@Model.Email</strong> adresiyle kayıtlı bir hesap varsa,
                    şifre sıfırlama linki gönderilmiştir. Lütfen gelen kutunuzu kontrol edin.
                </p>
                <a asp-controller="Auth" asp-action="Login"
                   class="inline-block mt-4 text-primary font-bold text-sm hover:underline">
                    Giriş sayfasına dön
                </a>
            </div>
        }
        else
        {
            <div class="mb-6 text-center">
                <h2 class="text-2xl font-bold font-headline text-on-surface">Şifremi Unuttum</h2>
                <p class="text-sm text-on-surface-variant mt-2">E-posta adresinizi girin, sıfırlama linki gönderelim.</p>
            </div>

            <form asp-action="ForgotPassword" asp-controller="Auth" method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-error text-sm font-semibold"></div>

                <div class="space-y-1">
                    <label asp-for="Email" class="block text-sm font-semibold text-on-surface-variant ml-1">E-posta Adresi</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-xl">mail</span>
                        <input asp-for="Email" class="w-full pl-12 pr-4 py-4 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/40 transition-all text-on-surface placeholder:text-outline/60 outline-none"
                               placeholder="ornek@dev4all.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-error text-xs ml-1 font-semibold"></span>
                </div>

                <button type="submit"
                        class="w-full text-white font-bold py-4 px-6 rounded-xl shadow-lg shadow-primary/20 transform active:scale-[0.98] transition-all duration-300"
                        style="background: linear-gradient(135deg, #003ec7, #0052ff); -webkit-text-fill-color: white;">
                    Şifre Sıfırlama Linki Gönder
                </button>

                <p class="text-center text-sm text-on-surface-variant">
                    <a asp-controller="Auth" asp-action="Login" class="text-primary font-bold hover:underline">Giriş sayfasına dön</a>
                </p>
            </form>
        }
    </div>
</div>
