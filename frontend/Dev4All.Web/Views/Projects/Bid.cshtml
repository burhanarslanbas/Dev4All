@{
    ViewData["Title"] = "Teklif Ver";
}

<!-- Header -->
<header class="flex justify-between items-center w-full px-6 h-16 bg-surface dark:bg-slate-950 fixed top-0 z-50">
    <div class="flex items-center gap-4">
        <a asp-action="Explore" class="active:scale-95 transition-transform text-on-surface">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">arrow_back</span>
        </a>
        <span class="text-xl font-extrabold text-[#131b2e] dark:text-slate-50 font-headline">Teklif Ver</span>
    </div>
    <div class="flex items-center gap-4">
        <div class="w-8 h-8 rounded-full overflow-hidden bg-surface-container">
            <img alt="User Profile Avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDvBek_ChbkjB1tsKPomxNhKHlXifJZ8PxE4w2V54ljy8NkzURuAW01l4Hs3B268pLV2DtUX_kWXoP2-uxJFv0jLodirFkzNSU_hRMGBNl2762np2oD7czUi_0g1XGRuDKljLUQ4xIw9hWclvIFS-M61miYnlTbJIAf8JfYLgjBG0d-34CRv8NsreOjq4FJylJly7gIHA_vqRrERoeqVj0QCBI65_he_vDvSC3Md1K_fsBhBV4375D5IVMaWP0OSFkYSWXbt2e8zG8" />
        </div>
    </div>
</header>

<!-- Main Content -->
<main class="flex-grow pt-16 pb-24 px-6 overflow-y-auto">
    <form class="max-w-2xl mx-auto py-8 space-y-8">
        <!-- Project Brief Reference (Optional but helpful context) -->
        <div class="bg-surface-container-low p-4 rounded-xl border border-outline-variant/30">
            <span class="text-xs font-bold text-primary uppercase tracking-widest block mb-1">Proje</span>
            <p class="text-on-surface font-semibold truncate">Yeni Nesil Marketplace Altyapısı Geliştirme</p>
        </div>
        
        <!-- Bid Amount Field -->
        <div>
            <label class="block text-sm font-bold text-on-surface-variant mb-3 uppercase tracking-widest">Teklif Tutarı (₺)</label>
            <div class="relative">
                <span class="absolute left-6 top-1/2 -translate-y-1/2 text-3xl font-bold text-primary">₺</span>
                <input class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-2xl py-6 pl-14 pr-6 text-4xl font-extrabold text-on-surface focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all placeholder:text-surface-variant" placeholder="0" type="number" required />
            </div>
            <div class="mt-3 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm text-on-surface-variant" style="font-variation-settings: 'FILL' 1;">account_balance_wallet</span>
                <p class="text-xs text-on-surface-variant font-medium">Platform komisyonu sonrası kazancınız: <span class="text-primary font-bold">₺0</span></p>
            </div>
        </div>
        
        <!-- Suggestion Note Field -->
        <div>
            <label class="block text-sm font-bold text-on-surface-variant mb-3 uppercase tracking-widest">Müşteriye Öneri Notunuz</label>
            <textarea class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-2xl p-6 text-on-surface focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all placeholder:text-on-surface-variant/40 resize-none font-body min-h-[160px]" placeholder="Neden bu proje için en iyi aday sizsiniz? Deneyimlerinizden ve yaklaşımınızdan bahsedin..." required></textarea>
        </div>
        
        <!-- Info Alert -->
        <div class="flex items-start gap-4 p-5 bg-primary-fixed/20 rounded-2xl border border-primary/10">
            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">info</span>
            <p class="text-sm text-on-secondary-fixed-variant leading-relaxed">
                Teklifiniz gönderildikten sonra müşteri tarafından incelenecek ve uygun bulunması durumunda mesaj yoluyla iletişime geçilecektir.
            </p>
        </div>
        
        <!-- Submit Button (Always visible on mobile scroll) -->
        <div class="pt-4">
            <button type="submit" class="w-full bg-primary text-on-primary py-5 rounded-2xl text-lg font-bold shadow-lg shadow-primary/20 hover:bg-primary-container hover:text-on-primary-container active:scale-[0.98] transition-all flex items-center justify-center gap-3">
                <span>Teklifi Gönder</span>
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">send</span>
            </button>
        </div>
    </form>
</main>

<!-- Bottom Navigation -->
<nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-safe h-20 bg-surface/80 dark:bg-slate-950/80 backdrop-blur-xl z-[80] border-t border-outline-variant/20 shadow-[0_-4px_32px_rgba(19,27,46,0.04)]" style="padding-bottom: env(safe-area-inset-bottom);">
    <a asp-action="Explore" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1.5 hover:text-primary active:scale-90 transition-all cursor-pointer">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">explore</span>
        <span class="font-label font-medium text-[10px] uppercase tracking-wider mt-1">Keşfet</span>
    </a>
    <a asp-action="Index" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1.5 hover:text-primary active:scale-90 transition-all cursor-pointer">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">assignment</span>
        <span class="font-label font-medium text-[10px] uppercase tracking-wider mt-1">Projeler</span>
    </a>
    <a href="#" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1.5 hover:text-primary active:scale-90 transition-all cursor-pointer">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">notifications</span>
        <span class="font-label font-medium text-[10px] uppercase tracking-wider mt-1">Bildirim</span>
    </a>
    <a href="#" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1.5 hover:text-primary active:scale-90 transition-all cursor-pointer">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">person</span>
        <span class="font-label font-medium text-[10px] uppercase tracking-wider mt-1">Profil</span>
    </a>
</nav>
