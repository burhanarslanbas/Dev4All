@{
    ViewData["Title"] = "Yeni Proje İlanı";
}

<!-- TopAppBar -->
<header class="bg-[#faf8ff] dark:bg-slate-950 flex justify-between items-center w-full px-6 h-16 docked full-width top-0 z-50 sticky">
    <div class="flex items-center gap-4">
        <a asp-action="Index" class="active:scale-95 transition-transform hover:bg-[#e2e7ff] p-2 rounded-full inline-block">
            <span class="material-symbols-outlined text-[#0052FF]" style="font-variation-settings: 'FILL' 1;">arrow_back</span>
        </a>
        <h1 class="font-['Manrope'] font-bold text-lg tracking-tight text-[#131b2e] dark:text-slate-50">Yeni Proje İlanı</h1>
    </div>
    <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-[#0052FF]">notifications</span>
        <div class="w-8 h-8 rounded-full overflow-hidden bg-surface-container">
            <img alt="Profile" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCtSYIUuchlNZKLhfb_MguhiKTTy5CREuoovY2WyMjhq0Z17bjzC9bD3xGszsDlINzA0J4xwesU7_o2p8NBQ3P_S-nwtggeL9jB-1z7f9rzcGXbHZurS5OWuObFLEXtp9zzurDh3xsNFuzTg70Y48ZNhkepJwmsqyM2wAhYOTeuJpWB5AyIiWKwQWQbcS6ChrfASqBjTuE-ApIy5xuNOMQ7oJFmZ_p0Ns3zZpp673-kONCEkyaPb5jj_9JVTsEZEclz5225IMULUIw" />
        </div>
    </div>
</header>
<main class="max-w-4xl mx-auto px-6 py-12 pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <!-- Left Column: Form -->
        <div class="lg:col-span-8 space-y-10">
            <form class="space-y-6">
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-secondary uppercase tracking-wider" for="title">Proje Başlığı</label>
                    <input class="w-full px-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/40 placeholder:text-outline transition-all text-on-surface" id="title" placeholder="Örn: E-Ticaret Mobil Uygulama Geliştirme" type="text" required />
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-secondary uppercase tracking-wider" for="details">Proje Detayları</label>
                    <textarea class="w-full px-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/40 placeholder:text-outline transition-all text-on-surface resize-none" id="details" placeholder="Projenin kapsamını, hedeflerini ve beklenen çıktıları detaylandırın..." rows="6" required></textarea>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-secondary uppercase tracking-wider" for="budget">Bütçe ($)</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline material-symbols-outlined text-sm">payments</span>
                            <input class="w-full pl-12 pr-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/40 placeholder:text-outline transition-all text-on-surface" id="budget" placeholder="5000" type="number" required />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-secondary uppercase tracking-wider">Teknolojiler</label>
                        <div class="flex flex-wrap gap-2 pt-1">
                            <button type="button" class="px-4 py-2 rounded-full bg-primary text-on-primary text-xs font-semibold shadow-sm">React</button>
                            <button type="button" class="px-4 py-2 rounded-full bg-surface-container-highest text-on-secondary-container text-xs font-semibold hover:bg-surface-variant transition-colors">.NET</button>
                            <button type="button" class="px-4 py-2 rounded-full bg-surface-container-highest text-on-secondary-container text-xs font-semibold hover:bg-surface-variant transition-colors">Node.js</button>
                            <button type="button" class="px-4 py-2 rounded-full bg-surface-container-highest text-on-secondary-container text-xs font-semibold hover:bg-surface-variant transition-colors">Flutter</button>
                            <button type="button" class="px-4 py-2 rounded-full bg-surface-container-low border border-outline-variant/30 text-on-secondary-container text-xs font-semibold hover:bg-surface-variant transition-colors">
                                <span class="material-symbols-outlined text-sm leading-none align-middle">add</span> Ekle
                            </button>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-secondary uppercase tracking-wider" for="delivery">Teslim Tarihi</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline material-symbols-outlined text-sm">calendar_today</span>
                            <input class="w-full pl-12 pr-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/40 transition-all text-on-surface" id="delivery" type="date" required />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-secondary uppercase tracking-wider" for="expiry">Teklif Bitiş Tarihi</label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-outline material-symbols-outlined text-sm">timer</span>
                            <input class="w-full pl-12 pr-5 py-4 bg-surface-container-low border-none rounded-xl focus:ring-2 focus:ring-primary/40 transition-all text-on-surface" id="expiry" type="date" required />
                        </div>
                    </div>
                </div>

                <!-- Bottom Action Bar (Fixed for Mobile/Desktop emphasis) -->
                <div class="fixed bottom-0 left-0 w-full bg-surface-container-lowest/80 backdrop-blur-xl px-6 py-6 border-t border-outline-variant/20 flex justify-center items-center z-40">
                    <button type="submit" class="max-w-4xl w-full py-4 rounded-xl bg-gradient-to-r from-primary to-primary-container text-on-primary font-headline font-bold text-lg shadow-[0_8px_32px_rgba(0,62,199,0.24)] hover:brightness-110 active:scale-[0.98] transition-all">
                        İlanı Yayınla
                    </button>
                </div>
            </form>
        </div>
        <!-- Right Column: Context/Info Card -->
        <div class="lg:col-span-4 sticky top-24">
            <div class="p-8 bg-surface-container-low rounded-3xl space-y-6">
                <div class="space-y-2">
                    <h3 class="font-headline font-bold text-xl text-on-surface">İpucu</h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed">Detaylı proje açıklamaları, doğru geliştiricilerin ilgisini çekmenize ve daha tutarlı teklifler almanıza yardımcı olur.</p>
                </div>
                <div class="space-y-4 pt-4">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">verified</span>
                        <p class="text-xs text-on-secondary-container">İlanınız Dev4All topluluğundaki onaylı 5000+ geliştiriciye anında ulaşır.</p>
                    </div>
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-primary-container" style="font-variation-settings: 'FILL' 1;">lock</span>
                        <p class="text-xs text-on-secondary-container">Bütçeniz güvenli ödeme sistemimiz tarafından koruma altına alınır.</p>
                    </div>
                </div>
                <div class="pt-6 border-t border-outline-variant/20">
                    <div class="rounded-2xl overflow-hidden aspect-video relative">
                        <img alt="Tech Team" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCMfF_5XzpqVUufyyWg2HRvUZoz5sUz7cRQo_WOk6ASajkMdUAJhVYtJ-g33vYtaGWS9RefqgbCXGbDU_cH96NiY0N56YuvfJDCrahnjyg5heyQYjpwjsSYqQcoiCWm6BuE6V-6DscfoEBch7KPOm9ayr4eJqhBmVuddjkuZwnWpoG_GxsRp7ZqqtjC4C-WV6Kkx5QusRV-Rqv18Eia3dLAfXNVz_09YpOWyhx6RT8MuEQJN2ny2kRbHQIhGVxgJ0Nfae2ynGyc0VE" />
                        <div class="absolute inset-0 bg-gradient-to-t from-primary/60 to-transparent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
