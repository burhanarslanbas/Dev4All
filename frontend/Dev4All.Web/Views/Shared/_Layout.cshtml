<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Dev4All</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface": "#faf8ff", "on-secondary-container": "#445a7f", "on-primary": "#ffffff", "tertiary-container": "#006f89", "on-surface-variant": "#434656", "surface-container": "#eaedff", "secondary": "#495f84", "secondary-fixed-dim": "#b1c7f2", "on-background": "#131b2e", "background": "#faf8ff", "tertiary-fixed": "#b7eaff", "surface-container-lowest": "#ffffff", "secondary-fixed": "#d6e3ff", "surface-container-high": "#e2e7ff", "on-primary-fixed": "#001452", "primary-fixed-dim": "#b7c4ff", "outline-variant": "#c3c5d9", "on-primary-fixed-variant": "#0038b6", "primary": "#003ec7", "surface-bright": "#faf8ff", "surface-variant": "#dae2fd", "tertiary-fixed-dim": "#4cd6ff", "error": "#ba1a1a", "on-tertiary": "#ffffff", "on-secondary-fixed": "#001b3d", "inverse-primary": "#b7c4ff", "on-tertiary-fixed": "#001f28", "error-container": "#ffdad6", "on-tertiary-fixed-variant": "#004e60", "on-error-container": "#93000a", "on-primary-container": "#dfe3ff", "surface-container-low": "#f2f3ff", "surface-container-highest": "#dae2fd", "surface-dim": "#d2d9f4", "on-secondary-fixed-variant": "#31476b", "on-secondary": "#ffffff", "inverse-surface": "#283044", "on-tertiary-container": "#bcecff", "tertiary": "#005569", "on-error": "#ffffff", "outline": "#737688", "inverse-on-surface": "#eef0ff", "primary-container": "#0052ff", "surface-tint": "#004ced", "secondary-container": "#bcd2fe", "on-surface": "#131b2e", "primary-fixed": "#dde1ff"
                    },
                    fontFamily: { "headline": ["Manrope"], "body": ["Inter"], "label": ["Inter"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .floating-label-group input:focus~label,
        .floating-label-group input:not(:placeholder-shown)~label { transform: translateY(-1.1rem) scale(0.75); color: #003ec7; }
        body { min-height: 100dvh; display: flex; flex-direction: column; }
    </style>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Dev4All.Web.styles.css" asp-append-version="true" />
</head>
<body class="bg-surface font-body text-on-surface flex flex-col min-h-screen max-w-[100vw] overflow-x-hidden">
    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
